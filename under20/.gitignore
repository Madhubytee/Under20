# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ─── Expo ────────────────────────────────────────────────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts

# ─── Native build output ─────────────────────────────────────────────────────
/ios
/android
.kotlin/
*.orig.*

# ─── Signing & secrets ───────────────────────────────────────────────────────
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.keystore
google-services.json
GoogleService-Info.plist

# ─── Environment variables ───────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# ─── Metro bundler ───────────────────────────────────────────────────────────
.metro-health-check*
metro.config.js.bak

# ─── Debug logs ──────────────────────────────────────────────────────────────
npm-debug.*
yarn-debug.*
yarn-error.*
*.log
logs/

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── OS files ────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ─── Editor & IDE ────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ─── Testing & coverage ──────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ─── Misc ────────────────────────────────────────────────────────────────────
*.pem
app-example
.cache/
tmp/
temp/

# ─── Large data files (Kaggle datasets - too large for git) ──────────────────
*.csv
*.csv.zip
*.pkl
